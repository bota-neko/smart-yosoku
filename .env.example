# ===== Supabase =====
# Supabase プロジェクト設定 > API から取得
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# サーバー専用（シード投入・管理操作。クライアントに絶対に露出させない）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===== 外部要因 自動取得（任意。未設定なら手動入力にフォールバック） =====
# 天気: 例 OpenWeatherMap / 気象庁ラッパー等
WEATHER_API_PROVIDER=
WEATHER_API_KEY=
WEATHER_DEFAULT_LOCATION=Kagoshima,JP

# 祝日: 例 内閣府祝日CSV / Nager.Date 等
HOLIDAY_API_PROVIDER=nager
HOLIDAY_COUNTRY=JP

# ===== アプリ =====
NEXT_PUBLIC_APP_NAME=smart-yosoku
# CSV 取込みの上限（バイト）
CSV_MAX_UPLOAD_BYTES=5242880
